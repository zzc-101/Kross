{
  "name": "@zzc-101/kross",
  "version": "0.1.0",
  "description": "Local-first terminal coding agent with auditable tools, durable sessions, and multi-model support.",
  "keywords": [
    "ai-agent",
    "coding-agent",
    "cli",
    "terminal",
    "tui"
  ],
  "type": "module",
  "license": "MIT",
  "bin": {
    "kross": "dist/kross.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zzc-101/Kross.git"
  },
  "bugs": {
    "url": "https://github.com/zzc-101/Kross/issues"
  },
  "homepage": "https://github.com/zzc-101/Kross#readme",
  "engines": {
    "node": ">=22.19.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run typecheck && npm run build:bundle",
    "build:bundle": "node scripts/build.mjs",
    "dev": "tsx packages/tui/src/main.tsx",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "package:check": "npm run build && node scripts/package-smoke.mjs",
    "check": "npm run typecheck && npm test -- --run && npm run package:check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@vscode/ripgrep": "^1.18.0",
    "better-sqlite3": "^12.11.1",
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.12",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "esbuild": "^0.28.1",
    "ink-testing-library": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}
