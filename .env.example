# Gateway
KROSS_ACCESS_TOKEN=
KROSS_PORT=8787
KROSS_IDLE_TIMEOUT_MS=1800000
KROSS_WORKSPACE_MEMORY=4294967296
KROSS_WORKSPACE_NANO_CPUS=2000000000
KROSS_WORKSPACE_PIDS=512
# 默认在 Gateway 退出时移除 Worker 容器并保留工作区卷，避免孤儿容器。
KROSS_STOP_WORKERS_ON_SHUTDOWN=true
# 反向代理跨域部署时使用逗号分隔；同源访问无需配置。
KROSS_ALLOWED_ORIGINS=
# 同一 Docker Engine 上部署多个 Kross 实例时必须设置不同值。
KROSS_MANAGER_ID=kross-cloud

# LLM example (choose one provider)
AGENT_LLM_PROVIDER=openai
AGENT_LLM_MODEL=gpt-5.6-sol
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional GitHub PR support
GH_TOKEN=

# Optional Web Push
KROSS_VAPID_PUBLIC_KEY=
KROSS_VAPID_PRIVATE_KEY=
KROSS_VAPID_SUBJECT=mailto:admin@example.com
